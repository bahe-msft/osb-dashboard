# direnv / Nix
.direnv/
result
result-*

# Go build and test artifacts
/osb-dashboard
*.test
*.out

# Playwright temporary artifacts (keep the CLI configuration tracked)
.playwright/*
!.playwright/cli.config.json
.playwright-cli/

# Downloaded frontend dependencies (keep licenses tracked)
web/assets/vendor/ghostty-web/*
!web/assets/vendor/ghostty-web/LICENSE
web/assets/vendor/ui/*
