# direnv / Nix
.direnv/
result
result-*

# Go build and test artifacts
/osb-dashboard
*.test
*.out

# Playwright temporary artifacts (keep the CLI configuration tracked)
.playwright/*
!.playwright/cli.config.json
.playwright-cli/

# Frontend runtime dependencies under web/assets/vendor are intentionally
# tracked so Go module consumers receive every file required by go:embed.
